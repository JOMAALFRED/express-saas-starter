# ── Application ───────────────────────────────────────────────
PORT=3000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://saas:saas@localhost:5432/saas_db

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Email (Nodemailer — utiliser Mailtrap en dev) ─────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@saas.local

# ── Trial ─────────────────────────────────────────────────────
TRIAL_DAYS=14
